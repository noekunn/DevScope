# Neo4j Aura Configuration (required for full graph features)
# Sign up at: https://neo4j.com/cloud/aura-free/
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# IBM watsonx.ai Configuration (optional — enables semantic enrichment)
# Sign up at: https://www.ibm.com/watsonx
WATSONX_API_KEY=your-watsonx-api-key-here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your-watsonx-project-id-here
